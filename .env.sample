# Kalshi API (required for authenticated trade-api calls)
KALSHI_API_KEY=

# Private key: path to PEM file or inline PEM
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# demo-api.kalshi.co when true
KALSHI_DEMO=false

# Optional base URL override
# KALSHI_BASE_PATH=

# --- Monitor ---
# Explicit market ticker to poll
# KALSHI_MONITOR_TICKER=

# Or discover first open market in series (e.g. Bitcoin 15m up/down)
# KALSHI_MONITOR_SERIES_TICKER=KXBTC15M

# Poll interval in ms (default 2000)
# KALSHI_MONITOR_INTERVAL_MS=2000

# Optional: append each line to this directory as kalshi-monitor.log
# KALSHI_MONITOR_LOG_DIR=logs
